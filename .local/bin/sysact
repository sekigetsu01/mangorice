#!/bin/sh
# tofi powermenu — dmenu style, pywal colours

case "$(readlink -f /sbin/init)" in
    *systemd*) ctl='systemctl' ;;
    *)         ctl='loginctl' ;;
esac

case "$(printf '🔃 reboot\n🖥️ shutdown' | tofi \
    --prompt-text 'Action: ' \
    --width 100% \
    --height 22 \
    --font-size 11 \
    --horizontal true \
    --anchor top \
    --margin-top 0 \
    --margin-bottom 0 \
    --margin-left 0 \
    --margin-right 0 \
    --padding-left 8 \
    --padding-right 8 \
    --padding-top 0 \
    --padding-bottom 0 \
    --border-width 0 \
    --outline-width 0 \
    --corner-radius 0 \
    --result-spacing 16 \
    --num-results 2 \
    --background-color "$(cat ~/.cache/wal/colors | sed -n '1p')" \
    --text-color "$(cat ~/.cache/wal/colors | sed -n '8p')" \
    --prompt-color "$(cat ~/.cache/wal/colors | sed -n '2p')" \
    --selection-color "$(cat ~/.cache/wal/colors | sed -n '3p')" \
    --selection-background "$(cat ~/.cache/wal/colors | sed -n '1p')")" in
    '🔃 reboot')   $ctl reboot -i ;;
    '🖥️ shutdown') $ctl poweroff -i ;;
    *) exit 1 ;;
esac
